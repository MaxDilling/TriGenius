{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "deploy": "deno task build && ./deploy.sh"
  },
  "imports": {
    "vite": "npm:vite@^6.0.7",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.3.4",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.0.0",
    "tailwindcss": "npm:tailwindcss@^4.0.0",
    "react": "npm:react@^19.0.0",
    "react-dom": "npm:react-dom@^19.0.0",
    "react-router-dom": "npm:react-router-dom@^7.1.1",
    "clsx": "npm:clsx@^2.1.1",
    "tailwind-merge": "npm:tailwind-merge@^2.6.0",
    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "@/": "./src/"
  },
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
